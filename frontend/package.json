{
  "name": "frontend",
  "version": "0.0.1",
  "description": "A Quasar Project",
  "productName": "chat-app",
  "author": "Radoslav Hlatky <rhlatky@gmail.com>",
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "eslint -c ./eslint.config.js \"./src*/**/*.{ts,js,cjs,mjs,vue}\"",
    "format": "prettier --write \"**/*.{js,ts,vue,css,scss,html,md,json}\" --ignore-path .gitignore",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "predev": "yarn workspace @chat-app/contracts build",
    "dev": "quasar dev",
    "prebuild": "yarn workspace @chat-app/contracts build",
    "build": "quasar build"
  },
  "dependencies": {
    "@chat-app/contracts": "*",
    "@multiavatar/multiavatar": "^1.0.7",
    "@quasar/extras": "^1.16.4",
    "pinia": "^3.0.1",
    "quasar": "^2.16.0",
    "sanitize-html": "^2.17.2",
    "socket.io-client": "^4.8.3",
    "vue": "^3.5.22",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@quasar/app-vite": "^2.5.1",
    "@types/node": "^22.19.11",
    "@types/sanitize-html": "^2.16.1",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vite-plugin-checker": "^0.12.0",
    "vitest": "^4.1.4",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.6"
  },
  "engines": {
    "node": "^28 || ^26 || ^24 || ^22.12",
    "npm": ">= 6.13.4",
    "yarn": ">= 1.21.1",
    "pnpm": ">= 10.0.0"
  }
}
